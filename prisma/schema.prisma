generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(cuid())
  name      String
  email     String      @unique
  password  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  config    UserConfig?
}

model UserConfig {
  id          String   @id @default(cuid())
  userId      String   @unique
  themeId     String   @default("dark")
  preferences String   @db.LongText
  updatedAt   DateTime @updatedAt
  theme       Theme    @relation(fields: [themeId], references: [name])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([themeId], map: "UserConfig_themeId_fkey")
}

model Theme {
  id        String       @id @default(cuid())
  name      String       @unique
  label     String
  isDefault Boolean      @default(false)
  cssVars   String?      @db.LongText   // JSON des variables CSS custom
  createdBy String?                     // userId du créateur (null = système)
  createdAt DateTime     @default(now())
  configs   UserConfig[]
}
model Category {
  id           String           @id @default(cuid())
  name         String           @unique
  type         CategoryType
  isFixed      Boolean          @default(false)
  createdAt    DateTime         @default(now())
  isArchived   Boolean          @default(false)
  fixedCharges FixedCharge[]
  projects     SavingsProject[]
  transactions Transaction[]
}

model Transaction {
  id         String   @id @default(cuid())
  month      DateTime
  amount     Float
  detail     String?
  pointed    Boolean  @default(false)
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tags       String   @default("[]") @db.LongText
  category   Category @relation(fields: [categoryId], references: [id])

  @@index([categoryId], map: "Transaction_categoryId_fkey")
}

model FixedCharge {
  id         String   @id @default(cuid())
  month      DateTime
  estimated  Float
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id])

  @@unique([month, categoryId])
  @@index([categoryId], map: "FixedCharge_categoryId_fkey")
}

model SavingsProject {
  id                String              @id @default(cuid())
  name              String
  targetAmount      Float?
  currentAmount     Float               @default(0)
  isActive          Boolean             @default(true)
  categoryId        String?
  transferredToId   String?             // id du projet cible lors d'une réaffectation
  transferredMonth  DateTime?           // mois de la réaffectation (pour retrouver l'allocation)
  transferredAmount Float?              // montant transféré (pour annulation exacte)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  allocations       SavingsAllocation[]
  category          Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
}

model SavingsAllocation {
  id         String         @id @default(cuid())
  month      DateTime
  percentage Float
  amount     Float
  projectId  String
  createdAt  DateTime       @default(now())
  project    SavingsProject @relation(fields: [projectId], references: [id])

  @@unique([month, projectId])
  @@index([projectId], map: "SavingsAllocation_projectId_fkey")
}

model BankAccount {
  id              String                @id @default(cuid())
  name            String                @unique
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  owner           String                @default("")
  reconciliations ReconciliationEntry[]
}

model Reconciliation {
  id           String                @id @default(cuid())
  month        DateTime              @unique
  totalReal    Float
  totalBdd     Float
  gap          Float
  note         String?
  adjustmentId String?
  createdAt    DateTime              @default(now())
  entries      ReconciliationEntry[]
}

model ReconciliationEntry {
  id               String         @id @default(cuid())
  reconciliationId String
  accountId        String
  balance          Float
  account          BankAccount    @relation(fields: [accountId], references: [id])
  reconciliation   Reconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)

  @@unique([reconciliationId, accountId])
  @@index([accountId])
  @@index([reconciliationId])
}

enum CategoryType {
  INCOME
  EXPENSE
  PROJECT
}
