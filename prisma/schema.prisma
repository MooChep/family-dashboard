generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  // "mysql" est le provider Prisma compatible MariaDB
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(cuid())
  // cuid() = identifiant unique généré automatiquement, plus sûr qu'un auto-increment
  name      String
  email     String      @unique
  password  String
  config    UserConfig?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model UserConfig {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  themeId     String   @default("dark")
  theme       Theme    @relation(fields: [themeId], references: [name])
  preferences Json     @default("{}")
  updatedAt   DateTime @updatedAt
}

model Theme {
  id        String       @id @default(cuid())
  name      String       @unique
  label     String
  isDefault Boolean      @default(false)
  createdAt DateTime     @default(now())
  configs   UserConfig[]
}