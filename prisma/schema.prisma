generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(cuid())
  name      String
  email     String      @unique
  password  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  config    UserConfig?

  // ── Relations Cerveau ──
  entries                Entry[]
  pushSubscriptions      PushSubscription[]
  notificationPreference NotificationPreference?
  nlpFeedbacks           NlpFeedback[]
}

model UserConfig {
  id          String   @id @default(cuid())
  userId      String   @unique
  themeId     String   @default("light")
  preferences String   @db.LongText
  updatedAt   DateTime @updatedAt
  theme       Theme    @relation(fields: [themeId], references: [name])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([themeId], map: "UserConfig_themeId_fkey")
}

model Theme {
  id        String       @id @default(cuid())
  name      String       @unique
  label     String
  isDefault Boolean      @default(false)
  cssVars   String?      @db.LongText
  createdBy String?
  createdAt DateTime     @default(now())
  configs   UserConfig[]
}

model Category {
  id            String           @id @default(cuid())
  name          String           @unique
  type          CategoryType
  isFixed       Boolean          @default(false)
  createdAt     DateTime         @default(now())
  isArchived    Boolean          @default(false)
  fixedCharges  FixedCharge[]
  projects      SavingsProject[]
  transactions  Transaction[]
  // ── Budget ──────────────────────────────────────────────────────────────
  budgetLines   BudgetLine[]
  budgetEntries BudgetEntry[]
}

model Transaction {
  id         String   @id @default(cuid())
  month      DateTime
  amount     Float
  detail     String?
  pointed    Boolean  @default(false)
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tags       String   @default("[]") @db.LongText
  category   Category @relation(fields: [categoryId], references: [id])

  @@index([categoryId], map: "Transaction_categoryId_fkey")
}

model FixedCharge {
  id         String   @id @default(cuid())
  month      DateTime
  estimated  Float
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id])

  @@unique([month, categoryId])
  @@index([categoryId], map: "FixedCharge_categoryId_fkey")
}

model SavingsProject {
  id                String              @id @default(cuid())
  name              String
  targetAmount      Float?
  currentAmount     Float               @default(0)
  isActive          Boolean             @default(true)
  categoryId        String?
  transferredToId   String?
  transferredMonth  DateTime?
  transferredAmount Float?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  allocations       SavingsAllocation[]
  category          Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
}

model SavingsAllocation {
  id         String         @id @default(cuid())
  month      DateTime
  percentage Float
  amount     Float
  projectId  String
  createdAt  DateTime       @default(now())
  project    SavingsProject @relation(fields: [projectId], references: [id])

  @@unique([month, projectId])
  @@index([projectId], map: "SavingsAllocation_projectId_fkey")
}

model BankAccount {
  id              String                @id @default(cuid())
  name            String                @unique
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  owner           String                @default("")
  reconciliations ReconciliationEntry[]
}

model Reconciliation {
  id           String                @id @default(cuid())
  month        DateTime              @unique
  totalReal    Float
  totalBdd     Float
  gap          Float
  note         String?
  adjustmentId String?
  createdAt    DateTime              @default(now())
  entries      ReconciliationEntry[]
}

model ReconciliationEntry {
  id               String         @id @default(cuid())
  reconciliationId String
  accountId        String
  balance          Float
  account          BankAccount    @relation(fields: [accountId], references: [id])
  reconciliation   Reconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)

  @@unique([reconciliationId, accountId])
  @@index([accountId])
  @@index([reconciliationId])
}

// ── Budget ─────────────────────────────────────────────────────────────────────

// BudgetLine : template récurrent d'une dépense/revenu prévu
// Ex: "Netflix 5€ tous les mois", "Carte bancaire 15€ tous les 3 mois"
model BudgetLine {
  id               String        @id @default(cuid())
  label            String // libellé lisible, ex: "Netflix"
  amount           Float // montant prévu
  categoryId       String
  recurrence       Recurrence    @default(NONE)
  recurrenceMonths Int? // si CUSTOM : tous les X mois (ex: 3)
  recurrenceStart  DateTime? // mois de référence pour calculer les échéances
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  category         Category      @relation(fields: [categoryId], references: [id])
  entries          BudgetEntry[]

  @@index([categoryId])
}

// BudgetEntry : instance mensuelle concrète d'une ligne de budget
// Peut être générée automatiquement depuis une BudgetLine récurrente,
// ou créée manuellement (budgetLineId = null)
model BudgetEntry {
  id           String      @id @default(cuid())
  month        DateTime // mois concerné (normalisé au 1er)
  label        String // peut différer du template si modif ponctuelle
  amount       Float // peut différer du template si modif ponctuelle
  categoryId   String
  budgetLineId String? // null = entrée ponctuelle sans récurrence
  isModified   Boolean     @default(false) // true = modifié après validation du mois
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  category     Category    @relation(fields: [categoryId], references: [id])
  budgetLine   BudgetLine? @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)

  @@index([month])
  @@index([categoryId])
  @@index([budgetLineId])
}

// BudgetMonth : état global du budget pour un mois donné
model BudgetMonth {
  id        String            @id @default(cuid())
  month     DateTime          @unique // normalisé au 1er du mois UTC
  status    BudgetMonthStatus @default(DRAFT)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum CategoryType {
  INCOME
  EXPENSE
  PROJECT
}

enum Recurrence {
  NONE // ponctuel, pas de récurrence
  MONTHLY // tous les mois
  QUARTERLY // tous les 3 mois
  ANNUAL // tous les 12 mois
  CUSTOM // tous les N mois (recurrenceMonths)
}

enum BudgetMonthStatus {
  DRAFT // en cours de préparation
  VALIDATED // verrouillé comme référence
}

// ── Enums Cerveau ──────────────────────────────────────────────────────────────

enum EntryType {
  NOTE
  TODO
  REMINDER
  LIST
  PROJECT
  DISCUSSION
  EVENT
}

enum EntryStatus {
  OPEN
  DONE
  CANCELLED
  ARCHIVED
  SNOOZED // Rappels uniquement
  PASSED // Événements uniquement
  PAUSED // Projets uniquement
}

enum EntryPriority {
  LOW // !
  MEDIUM // !!
  HIGH // !!!
}

enum EntryAssignee {
  SHARED
  ILAN
  CAMILLE
}

enum EntrySource {
  CAPTURE
  VIDE_TETE
  TEMPLATE
  RECURRING
}

enum EntryFormat {
  PLAIN
  MARKDOWN
}

enum NotificationType {
  REMINDER
  EVENT
  ENRICHMENT
  BRIEF
  RECAP
  ESCALATION
}

// ── Modèle Cerveau ────────────────────────────────────────────────────────────

model Entry {
  id String @id @default(cuid())

  // ── Champs communs ──
  type          EntryType
  content       String        @db.Text
  status        EntryStatus   @default(OPEN)
  authorId      String
  assignedTo    EntryAssignee @default(SHARED)
  source        EntrySource   @default(CAPTURE)
  contentFormat EntryFormat   @default(PLAIN)
  isPinned      Boolean        @default(false)  // Notes uniquement
  isUrgent      Boolean        @default(false)  // Discussions uniquement
  priority      EntryPriority?                  // Todos + Rappels uniquement

  // ── Temporel ──
  dueDate      DateTime? // Rappels (obligatoire), Todos (optionnel)
  snoozedUntil DateTime? // Rappels uniquement
  archivedAt   DateTime? // renseigné à l'archivage

  // ── Récurrence ──
  recurrenceRule String? // iCal RRULE

  // ── Sous-tâches / hiérarchie (dormant v1) ──
  parentId String?
  parent   Entry?  @relation("EntryChildren", fields: [parentId], references: [id])
  children Entry[] @relation("EntryChildren")

  // ── Projet ──
  projectId      String?
  project        Entry?  @relation("ProjectEntries", fields: [projectId], references: [id])
  projectEntries Entry[] @relation("ProjectEntries")

  // ── Événement ──
  startDate   DateTime?
  endDate     DateTime?
  allDay      Boolean   @default(false)
  location    String?
  locationLat Float? // dormant v1
  locationLng Float? // dormant v1
  calendarId  String? // FK Calendar, dormant v1
  externalUid String? // sync Google Calendar, dormant v1

  // ── Discussion ──
  description      String?   @db.Text
  enrichNotifiedAt DateTime?

  // ── Pièces jointes ──
  attachmentPath String?
  attachmentMime String?
  attachmentSize Int?

  // ── Lieu (dormant v1) ──
  placeId String? // FK Place

  // ── Relations ──
  author         User              @relation(fields: [authorId], references: [id])
  tags           EntryTag[]
  listItems      ListItem[]
  eventReminders EventReminder[]
  notifications  NotificationLog[]

  // ── Métadonnées ──
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Index ──
  @@index([authorId, type, status])
  @@index([authorId, status, dueDate])
  @@index([projectId, status, dueDate])
  @@index([type, status, archivedAt])
  @@index([status, archivedAt])
  @@index([calendarId]) // dormant v1
  @@index([placeId]) // dormant v1
  @@fulltext([content])
}

// ── Modèles secondaires Cerveau ────────────────────────────────────────────────

model Tag {
  id        String     @id @default(cuid())
  name      String     @unique
  entries   EntryTag[]
  createdAt DateTime   @default(now())
}

model EntryTag {
  entryId String
  tagId   String
  entry   Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([entryId, tagId])
  @@index([tagId])
}

model ListItem {
  id          String    @id @default(cuid())
  entryId     String
  content     String
  quantity    String?
  checked     Boolean   @default(false)
  addedById   String
  checkedById String?
  addedAt     DateTime  @default(now())
  checkedAt   DateTime?
  archivedAt  DateTime?

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId, checked])
  @@index([entryId, archivedAt])
}

model EventReminder {
  id      String    @id @default(cuid())
  entryId String
  delay   String // ISO 8601 duration: "-P1D", "-PT2H"
  sentAt  DateTime?

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
}

model NotificationPreference {
  id                 String   @id @default(cuid())
  userId             String   @unique
  reminderDelays     String   @default("[\"PT0S\",\"-PT15M\",\"-PT1H\"]")
  snoozeTonightHour  String   @default("20:00")
  eventDefaultDelays String   @default("[\"-P1D\",\"-PT2H\"]")
  enrichDelay        Int      @default(60)
  briefEnabled       Boolean  @default(false)
  briefTime          String   @default("08:00")
  recapEnabled       Boolean  @default(false)
  recapDay           Int      @default(0)
  recapTime          String   @default("19:00")
  silenceEnabled     Boolean  @default(false)
  silenceStart       String?
  silenceEnd         String?
  escalationEnabled  Boolean  @default(false)
  escalationDelay    Int      @default(30)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model NotificationLog {
  id          String           @id @default(cuid())
  userId      String
  entryId     String?
  type        NotificationType
  scheduledAt DateTime
  sentAt      DateTime?
  dismissedAt DateTime?
  snoozedTo   DateTime?

  entry Entry? @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([userId, type, scheduledAt])
  @@index([entryId])
  @@index([sentAt])
  @@index([scheduledAt, sentAt])
}

model PushSubscription {
  id           String   @id @default(cuid())
  userId       String
  endpoint     String   @db.Text
  p256dh       String   @db.Text
  auth         String
  userAgent    String?
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @updatedAt
  User         User     @relation(fields: [userId], references: [id])

  @@unique([userId, endpoint(length: 255)])
  @@index([userId])
}

model NlpFeedback {
  id        String    @id @default(cuid())
  userId    String
  input     String    @db.Text
  predicted EntryType
  corrected EntryType
  createdAt DateTime  @default(now())
  User      User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([predicted, corrected])
}

// ── Modèles dormants v1 ────────────────────────────────────────────────────────

model Calendar {
  id        String           @id @default(cuid())
  name      String
  color     String?
  createdAt DateTime         @default(now())
  members   CalendarMember[]
}

model CalendarMember {
  calendarId String
  userId     String
  role       String @default("MEMBER") // OWNER | MEMBER

  calendar Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@id([calendarId, userId])
}

model Place {
  id      String @id @default(cuid())
  slug    String @unique // "maison", "travail"
  label   String // "Maison", "Bureau"
  lat     Float?
  lng     Float?
  radius  Int    @default(100) // mètres
  ownerId String
}
