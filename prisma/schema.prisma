generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(cuid())
  name      String
  email     String      @unique
  password  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  config    UserConfig?
}

model UserConfig {
  id          String   @id @default(cuid())
  userId      String   @unique
  themeId     String   @default("light")
  preferences String   @db.LongText
  updatedAt   DateTime @updatedAt
  theme       Theme    @relation(fields: [themeId], references: [name])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([themeId], map: "UserConfig_themeId_fkey")
}

model Theme {
  id        String       @id @default(cuid())
  name      String       @unique
  label     String
  isDefault Boolean      @default(false)
  cssVars   String?      @db.LongText
  createdBy String?
  createdAt DateTime     @default(now())
  configs   UserConfig[]
}

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  type          CategoryType
  isFixed       Boolean       @default(false)
  createdAt     DateTime      @default(now())
  isArchived    Boolean       @default(false)
  fixedCharges  FixedCharge[]
  projects      SavingsProject[]
  transactions  Transaction[]
  // ── Budget ──────────────────────────────────────────────────────────────
  budgetLines   BudgetLine[]
  budgetEntries BudgetEntry[]
}

model Transaction {
  id         String   @id @default(cuid())
  month      DateTime
  amount     Float
  detail     String?
  pointed    Boolean  @default(false)
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tags       String   @default("[]") @db.LongText
  category   Category @relation(fields: [categoryId], references: [id])

  @@index([categoryId], map: "Transaction_categoryId_fkey")
}

model FixedCharge {
  id         String   @id @default(cuid())
  month      DateTime
  estimated  Float
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id])

  @@unique([month, categoryId])
  @@index([categoryId], map: "FixedCharge_categoryId_fkey")
}

model SavingsProject {
  id                String              @id @default(cuid())
  name              String
  targetAmount      Float?
  currentAmount     Float               @default(0)
  isActive          Boolean             @default(true)
  categoryId        String?
  transferredToId   String?
  transferredMonth  DateTime?
  transferredAmount Float?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  allocations       SavingsAllocation[]
  category          Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
}

model SavingsAllocation {
  id         String         @id @default(cuid())
  month      DateTime
  percentage Float
  amount     Float
  projectId  String
  createdAt  DateTime       @default(now())
  project    SavingsProject @relation(fields: [projectId], references: [id])

  @@unique([month, projectId])
  @@index([projectId], map: "SavingsAllocation_projectId_fkey")
}

model BankAccount {
  id              String                @id @default(cuid())
  name            String                @unique
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  owner           String                @default("")
  reconciliations ReconciliationEntry[]
}

model Reconciliation {
  id           String                @id @default(cuid())
  month        DateTime              @unique
  totalReal    Float
  totalBdd     Float
  gap          Float
  note         String?
  adjustmentId String?
  createdAt    DateTime              @default(now())
  entries      ReconciliationEntry[]
}

model ReconciliationEntry {
  id               String         @id @default(cuid())
  reconciliationId String
  accountId        String
  balance          Float
  account          BankAccount    @relation(fields: [accountId], references: [id])
  reconciliation   Reconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)

  @@unique([reconciliationId, accountId])
  @@index([accountId])
  @@index([reconciliationId])
}

// ── Budget ─────────────────────────────────────────────────────────────────────

// BudgetLine : template récurrent d'une dépense/revenu prévu
// Ex: "Netflix 5€ tous les mois", "Carte bancaire 15€ tous les 3 mois"
model BudgetLine {
  id               String      @id @default(cuid())
  label            String      // libellé lisible, ex: "Netflix"
  amount           Float       // montant prévu
  categoryId       String
  recurrence       Recurrence  @default(NONE)
  recurrenceMonths Int?        // si CUSTOM : tous les X mois (ex: 3)
  recurrenceStart  DateTime?   // mois de référence pour calculer les échéances
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  category         Category    @relation(fields: [categoryId], references: [id])
  entries          BudgetEntry[]

  @@index([categoryId])
}

// BudgetEntry : instance mensuelle concrète d'une ligne de budget
// Peut être générée automatiquement depuis une BudgetLine récurrente,
// ou créée manuellement (budgetLineId = null)
model BudgetEntry {
  id           String      @id @default(cuid())
  month        DateTime    // mois concerné (normalisé au 1er)
  label        String      // peut différer du template si modif ponctuelle
  amount       Float       // peut différer du template si modif ponctuelle
  categoryId   String
  budgetLineId String?     // null = entrée ponctuelle sans récurrence
  isModified   Boolean     @default(false) // true = modifié après validation du mois
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  category     Category    @relation(fields: [categoryId], references: [id])
  budgetLine   BudgetLine? @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)

  @@index([month])
  @@index([categoryId])
  @@index([budgetLineId])
}

// BudgetMonth : état global du budget pour un mois donné
model BudgetMonth {
  id        String            @id @default(cuid())
  month     DateTime          @unique // normalisé au 1er du mois UTC
  status    BudgetMonthStatus @default(DRAFT)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum CategoryType {
  INCOME
  EXPENSE
  PROJECT
}

enum Recurrence {
  NONE      // ponctuel, pas de récurrence
  MONTHLY   // tous les mois
  QUARTERLY // tous les 3 mois
  ANNUAL    // tous les 12 mois
  CUSTOM    // tous les N mois (recurrenceMonths)
}

enum BudgetMonthStatus {
  DRAFT     // en cours de préparation
  VALIDATED // verrouillé comme référence
}