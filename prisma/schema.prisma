generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(cuid())
  name      String
  email     String      @unique
  password  String
  gender               Gender              @default(NEUTRAL) // pour les titres de seigneur Labeur
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  config               UserConfig?
  cerveauEntries       CerveauEntry[]      @relation("CerveauCreatedBy")
  pushSubscriptions    PushSubscription[]
  cerveauPreferences   CerveauPreferences?
  cerveauTemplates     CerveauTemplate[]   @relation("CerveauTemplateCreatedBy")
  parcheminNotes           ParcheminNote[]         @relation("ParcheminNoteCreatedBy")
  parcheminPreferences     ParcheminPreferences?
  // ── Labeur ──────────────────────────────────────────────────────────────
  labeurTasksCreated   LabeurTask[]        @relation("LabeurTaskCreatedBy")
  labeurCompletions    LabeurCompletion[]  @relation("LabeurCompletionUser")
  ecuBalance           EcuBalance?         @relation("EcuBalanceUser")
  labeurMarketItems    LabeurMarketItem[]  @relation("LabeurMarketCreatedBy")
  labeurPurchases      LabeurPurchase[]    @relation("LabeurPurchaseUser")
}

model UserConfig {
  id          String   @id @default(cuid())
  userId      String   @unique
  themeId     String   @default("light")
  preferences String   @db.LongText
  updatedAt   DateTime @updatedAt
  theme       Theme    @relation(fields: [themeId], references: [name])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([themeId], map: "UserConfig_themeId_fkey")
}

model Theme {
  id        String       @id @default(cuid())
  name      String       @unique
  label     String
  isDefault Boolean      @default(false)
  cssVars   String?      @db.LongText
  createdBy String?
  createdAt DateTime     @default(now())
  configs   UserConfig[]
}

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  type          CategoryType
  isFixed       Boolean       @default(false)
  createdAt     DateTime      @default(now())
  isArchived    Boolean       @default(false)
  fixedCharges  FixedCharge[]
  projects      SavingsProject[]
  transactions  Transaction[]
  // ── Budget ──────────────────────────────────────────────────────────────
  budgetLines   BudgetLine[]
  budgetEntries BudgetEntry[]
}

model Transaction {
  id         String   @id @default(cuid())
  month      DateTime
  amount     Float
  detail     String?
  pointed    Boolean  @default(false)
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tags       String   @default("[]") @db.LongText
  category   Category @relation(fields: [categoryId], references: [id])

  @@index([categoryId], map: "Transaction_categoryId_fkey")
}

model FixedCharge {
  id         String   @id @default(cuid())
  month      DateTime
  estimated  Float
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id])

  @@unique([month, categoryId])
  @@index([categoryId], map: "FixedCharge_categoryId_fkey")
}

model SavingsProject {
  id                String              @id @default(cuid())
  name              String
  targetAmount      Float?
  currentAmount     Float               @default(0)
  isActive          Boolean             @default(true)
  categoryId        String?
  transferredToId   String?
  transferredMonth  DateTime?
  transferredAmount Float?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  allocations       SavingsAllocation[]
  category          Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
}

model SavingsAllocation {
  id         String         @id @default(cuid())
  month      DateTime
  percentage Float
  amount     Float
  projectId  String
  createdAt  DateTime       @default(now())
  project    SavingsProject @relation(fields: [projectId], references: [id])

  @@unique([month, projectId])
  @@index([projectId], map: "SavingsAllocation_projectId_fkey")
}

model BankAccount {
  id              String                @id @default(cuid())
  name            String                @unique
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  owner           String                @default("")
  reconciliations ReconciliationEntry[]
}

model Reconciliation {
  id           String                @id @default(cuid())
  month        DateTime
  totalReal    Float
  totalBdd     Float
  gap          Float
  note         String?
  adjustmentId String?
  createdAt    DateTime              @default(now())
  entries      ReconciliationEntry[]
}

model ReconciliationEntry {
  id               String         @id @default(cuid())
  reconciliationId String
  accountId        String
  balance          Float
  account          BankAccount    @relation(fields: [accountId], references: [id])
  reconciliation   Reconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)

  @@unique([reconciliationId, accountId])
  @@index([accountId])
  @@index([reconciliationId])
}

// ── Budget ─────────────────────────────────────────────────────────────────────

// BudgetLine : template récurrent d'une dépense/revenu prévu
// Ex: "Netflix 5€ tous les mois", "Carte bancaire 15€ tous les 3 mois"
model BudgetLine {
  id               String      @id @default(cuid())
  label            String      // libellé lisible, ex: "Netflix"
  amount           Float       // montant prévu
  categoryId       String
  recurrence       Recurrence  @default(NONE)
  recurrenceMonths Int?        // si CUSTOM : tous les X mois (ex: 3)
  recurrenceStart  DateTime?   // mois de référence pour calculer les échéances
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  category         Category    @relation(fields: [categoryId], references: [id])
  entries          BudgetEntry[]

  @@index([categoryId])
}

// BudgetEntry : instance mensuelle concrète d'une ligne de budget
// Peut être générée automatiquement depuis une BudgetLine récurrente,
// ou créée manuellement (budgetLineId = null)
model BudgetEntry {
  id           String      @id @default(cuid())
  month        DateTime    // mois concerné (normalisé au 1er)
  label        String      // peut différer du template si modif ponctuelle
  amount       Float       // peut différer du template si modif ponctuelle
  categoryId   String
  budgetLineId String?     // null = entrée ponctuelle sans récurrence
  isModified   Boolean     @default(false) // true = modifié après validation du mois
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  category     Category    @relation(fields: [categoryId], references: [id])
  budgetLine   BudgetLine? @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)

  @@index([month])
  @@index([categoryId])
  @@index([budgetLineId])
}

// BudgetMonth : état global du budget pour un mois donné
model BudgetMonth {
  id        String            @id @default(cuid())
  month     DateTime          @unique // normalisé au 1er du mois UTC
  status    BudgetMonthStatus @default(DRAFT)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

// ── Cerveau ────────────────────────────────────────────────────────────────────

model CerveauEntry {
  id           String      @id @default(cuid())
  type         EntryType
  title        String
  body         String?     @db.Text
  status       EntryStatus @default(ACTIVE)
  priority     Priority?
  assignedTo   AssignedTo  @default(BOTH)
  pinned       Boolean     @default(false)

  dueDate      DateTime?
  remindAt     DateTime?
  snoozedUntil DateTime?

  createdById  String
  createdBy    User        @relation("CerveauCreatedBy", fields: [createdById], references: [id])

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  archivedAt   DateTime?
  doneAt       DateTime?

  tags         String?           // JSON array: '["santé","maison"]'
  recurrence   String?           // "quotidien" | "hebdo" | "mensuel" | "annuel"

  notificationCount  Int       @default(0)
  lastNotifiedAt     DateTime?

  listItems    CerveauListItem[]
  children     CerveauEntry[]    @relation("ProjectChildren")
  parentId     String?
  parent       CerveauEntry?     @relation("ProjectChildren", fields: [parentId], references: [id])

  @@index([status])
  @@index([type])
  @@index([assignedTo])
  @@index([dueDate])
  @@index([remindAt])
}

model CerveauListItem {
  id        String       @id @default(cuid())
  entryId   String
  entry     CerveauEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  label     String
  checked   Boolean      @default(false)
  order     Int          @default(0)
  createdAt DateTime     @default(now())

  @@index([entryId])
}

// ── Push Notifications ─────────────────────────────────────────────────────────

model PushSubscription {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  endpoint     String   @db.Text
  p256dh       String   @db.Text
  auth         String
  userAgent    String?
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("PushSubscription")
}

model CerveauPreferences {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eveningStartsAt    String    @default("19:00")
  eventLeadTime      Int       @default(1440)
  quietFrom          String?
  quietUntil         String?
  morningDigestAt    String?   @default("08:00")
  lastDailyDigestAt  DateTime?
  lastWeeklyRecapAt  DateTime?
  weeklyRecapEnabled Boolean   @default(true)
  snoozeSlot1Label   String    @default("15 min")
  snoozeSlot1Minutes Int       @default(15)
  snoozeSlot2Label   String    @default("1 heure")
  snoozeSlot2Minutes Int       @default(60)
  snoozeSlot3Label   String    @default("Ce soir")
  snoozeSlot3Minutes Int?
  snoozeSlot3Dynamic Boolean   @default(true)
  snoozeDefaultSlot  Int       @default(2)
  updatedAt          DateTime  @updatedAt
}

model CerveauTemplate {
  id            String     @id @default(cuid())
  name          String
  shortcut      String?
  type          EntryType
  titlePattern  String
  body          String?    @db.Text
  priority      Priority?
  assignedTo    AssignedTo @default(BOTH)
  tags          String?    @db.Text
  recurrence    String?

  items          CerveauTemplateItem[]

  childTemplates CerveauTemplate[]  @relation("TemplateChildren")
  parentId       String?
  parent         CerveauTemplate?   @relation("TemplateChildren", fields: [parentId], references: [id])

  createdById    String
  createdBy      User               @relation("CerveauTemplateCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([shortcut])
  @@index([createdById])
  @@index([parentId])
}

model CerveauTemplateItem {
  id         String          @id @default(cuid())
  templateId String
  template   CerveauTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  label      String
  order      Int             @default(0)

  @@index([templateId])
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum CategoryType {
  INCOME
  EXPENSE
  PROJECT
}

enum Recurrence {
  NONE      // ponctuel, pas de récurrence
  MONTHLY   // tous les mois
  QUARTERLY // tous les 3 mois
  ANNUAL    // tous les 12 mois
  CUSTOM    // tous les N mois (recurrenceMonths)
}

enum BudgetMonthStatus {
  DRAFT     // en cours de préparation
  VALIDATED // verrouillé comme référence
}

enum EntryType {
  NOTE
  TODO
  REMINDER
  LIST
  PROJECT
  DISCUSSION
  EVENT
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum AssignedTo {
  ILAN
  CAMILLE
  BOTH
}

enum EntryStatus {
  ACTIVE
  DONE
  ARCHIVED
  SNOOZED
}

// ── Gamelle ─────────────────────────────────────────────────────────────────────

enum BaseUnit {
  GRAM
  MILLILITER
  UNIT
}

enum ShoppingListStatus {
  DRAFT    // check placard en cours
  ACTIVE   // liste finalisée, courses en cours
  ARCHIVED // courses validées
}

enum SlotType {
  DATED
  FLOATING
}

enum Period {
  LUNCH
  DINNER
}

enum RecipeCategory {
  STARTER
  MAIN
  DESSERT
  OTHER
}

model Aisle {
  id          String                @id @default(cuid())
  name        String
  emoji       String?
  order       Int
  ingredients IngredientReference[]
}

model IngredientReference {
  id                 String   @id @default(cuid())
  name               String   @unique
  baseUnit           BaseUnit
  aisleId            String
  aisle              Aisle    @relation(fields: [aisleId], references: [id])
  defaultQuantity    Float?
  conversions        Json?
  quickBuyQuantities Json?
  imageUrl           String?

  recipeIngredients  RecipeIngredient[]
  shoppingListItems  ShoppingListItem[]
  inventory          Inventory?
  substitutionRules  SubstitutionRule[]

  @@index([aisleId])
}

model Recipe {
  id              String             @id @default(cuid())
  title           String
  description     String?            @db.Text
  imageLocal      String
  preparationTime Int?
  cookingTime     Int?
  basePortions    Int                @default(4)
  calories        Int?
  utensils        String?            @db.Text
  steps           Json
  sourceUrl       String?
  jowId           String?            @unique
  category        RecipeCategory?    @default(OTHER)
  createdAt       DateTime           @default(now())
  ingredients     RecipeIngredient[]
  planningSlots   PlanningSlot[]
  like            RecipeLike?
  shoppingListRecipes ShoppingListRecipe[]
}

model RecipeIngredient {
  id          String              @id @default(cuid())
  recipeId    String
  recipe      Recipe              @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  referenceId String
  reference   IngredientReference @relation(fields: [referenceId], references: [id])
  quantity        Float
  displayQuantity Float           @default(0)
  displayUnit     String
  isOptional      Boolean         @default(false)
  isStaple        Boolean         @default(false)
  isIgnored       Boolean         @default(false)

  @@index([recipeId])
  @@index([referenceId])
}

model SubstitutionRule {
  id          String              @id @default(cuid())
  jowName     String              @unique
  referenceId String
  reference   IngredientReference @relation(fields: [referenceId], references: [id])
  createdAt   DateTime            @default(now())

  @@index([referenceId])
}

model PlanningSlot {
  id               String    @id @default(cuid())
  recipeId         String
  recipe           Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  type             SlotType
  scheduledDate    DateTime?
  period           Period?
  portions         Int
  portionsConsumed Int       @default(0)
  addedAt          DateTime  @default(now())
  lastPurchasedAt  DateTime?

  @@index([recipeId])
  @@index([scheduledDate])
}

model ShoppingList {
  id          String              @id @default(cuid())
  generatedAt DateTime            @default(now())
  weekStart   DateTime
  status      ShoppingListStatus  @default(DRAFT)
  archivedAt  DateTime?
  items       ShoppingListItem[]
  recipes     ShoppingListRecipe[]
}

model ShoppingListItem {
  id               String        @id @default(cuid())
  shoppingListId   String
  shoppingList     ShoppingList  @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  referenceId      String?
  reference        IngredientReference? @relation(fields: [referenceId], references: [id])
  label            String
  quantity         Float?
  displayUnit      String?
  plannedQuantity  Float?
  skipped          Boolean       @default(false)
  purchased        Boolean       @default(false)
  purchasedQuantity Float?
  isManual         Boolean       @default(false)

  @@index([shoppingListId])
  @@index([referenceId])
}

model Inventory {
  id          String              @id @default(cuid())
  referenceId String              @unique
  reference   IngredientReference @relation(fields: [referenceId], references: [id])
  quantity    Float
  updatedAt   DateTime            @updatedAt
}

// ── Parchemin ──────────────────────────────────────────────────────────────────────

enum NoteFormat {
  TEXT
  CHECKLIST
  BULLETS
  NUMBERED
  REMINDER
}

model ParcheminNote {
  id          String     @id @default(cuid())
  title       String
  format      NoteFormat @default(TEXT)
  body        String?    @db.Text
  pinned      Boolean    @default(false)
  parentId    String?
  parent      ParcheminNote?  @relation("NoteChildren", fields: [parentId], references: [id])
  children    ParcheminNote[] @relation("NoteChildren")
  items       ParcheminItem[]
  notifAt     DateTime?
  notifTo     String?
  notifBody   String?
  notifSentAt DateTime?
  dueDate     DateTime?
  createdById String
  createdBy   User        @relation("ParcheminNoteCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  archivedAt  DateTime?

  @@index([parentId])
  @@index([createdById])
  @@index([notifAt])
  @@index([pinned])
  @@index([dueDate])
}

model ParcheminItem {
  id      String    @id @default(cuid())
  noteId  String
  note    ParcheminNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  label   String
  checked Boolean   @default(false)
  order   Int       @default(0)

  @@index([noteId])
}

model ParcheminPreferences {
  id               String  @id @default(cuid())
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifyOnCreate   Boolean @default(true)
}

// ── Labeur ─────────────────────────────────────────────────────────────────────

// Tâche ménagère ou corvée ponctuelle — cœur du module Labeur
model LabeurTask {
  id                   String            @id @default(cuid())
  title                String            // intitulé de la tâche
  description          String?           @db.Text
  type                 LabeurTaskType
  isShared             Boolean           @default(false) // true = nécessite 2 validations
  ecuValue             Int               // valeur en écu (fixe à la création)
  // taux de contribution à l'inflation par jour de retard : ecuValue × rate × jours
  inflationContribRate Float             @default(0.01)
  streakCount          Int               @default(0)    // roadmap Streak : occurrences consécutives à temps
  dueDate                   DateTime?         // échéance pour les tâches ONESHOT uniquement
  oneshotReminderSentAt     DateTime?         // date d'envoi du rappel push ONESHOT (null = pas encore envoyé)
  status               LabeurTaskStatus  @default(ACTIVE)
  createdById          String
  createdBy            User              @relation("LabeurTaskCreatedBy", fields: [createdById], references: [id])
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  recurrence           LabeurRecurrence?
  completions          LabeurCompletion[]
  inflationStates      LabeurInflationState[]

  @@index([status])
  @@index([type])
  @@index([createdById])
}

// Configuration de récurrence d'une tâche périodique (1:1 avec LabeurTask)
model LabeurRecurrence {
  id              String              @id @default(cuid())
  taskId          String              @unique
  task            LabeurTask          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  frequency       LabeurTaskFrequency
  intervalDays    Int?                // si CUSTOM : nombre de jours entre deux occurrences
  nextDueAt       DateTime            // prochaine échéance stockée en UTC, interprétée en Europe/Paris
  lastGeneratedAt DateTime?           // date de la dernière régénération après complétion

  @@index([nextDueAt])
}

// Enregistrement d'une réalisation de tâche par un membre
model LabeurCompletion {
  id           String     @id @default(cuid())
  taskId       String
  task         LabeurTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation("LabeurCompletionUser", fields: [userId], references: [id])
  ecuAwarded   Int        // écu crédités au moment de la réalisation (valeur courante)
  completedAt  DateTime   @default(now())

  @@index([taskId])
  @@index([userId])
  @@index([completedAt])
}

// Solde d'écu d'un membre du foyer — un seul enregistrement par utilisateur
model EcuBalance {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation("EcuBalanceUser", fields: [userId], references: [id], onDelete: Cascade)
  balance        Int      @default(0) // solde courant dépensable (diminue à l'achat)
  totalEcuEarned Int      @default(0) // cumul historique gagné — base des titres, ne diminue jamais
  updatedAt      DateTime @updatedAt
}

// Article disponible dans le Marché des récompenses
model LabeurMarketItem {
  id             String                     @id @default(cuid())
  title          String
  description    String?                    @db.Text
  ecuPrice       Int                        // prix de base en écu (inflation appliquée à l'affichage)
  type           LabeurMarketItemType
  stock          Int?                       // null = infini ; > 0 = nombre d'utilisations restantes
  initialStock   Int?                       // stock d'origine pour la réinitialisation périodique
  resetFrequency LabeurMarketResetFrequency? // réactivation périodique du stock
  lastResetAt    DateTime?                  // référence pour calculer la prochaine réactivation
  isActive       Boolean                    @default(true)
  isSealable     Boolean                    @default(true) // false = toujours accessible même sous malédiction
  createdById    String
  createdBy      User                       @relation("LabeurMarketCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  purchases      LabeurPurchase[]

  @@index([isActive])
  @@index([createdById])
}

// Achat ou contribution sur un article du Marché
model LabeurPurchase {
  id           String               @id @default(cuid())
  itemId       String
  item         LabeurMarketItem     @relation(fields: [itemId], references: [id])
  userId       String
  user         User                 @relation("LabeurPurchaseUser", fields: [userId], references: [id])
  type         LabeurPurchaseType
  ecuSpent     Int                  // écu dépensés par CE membre pour cette transaction
  isComplete   Boolean              @default(false) // true = achat finalisé (individuel ou 100 % collectif)
  purchasedAt  DateTime             @default(now())

  @@index([itemId])
  @@index([userId])
}

// État d'inflation par tâche en retard — une entrée par tâche active en retard
// Supprimée immédiatement quand la tâche est réalisée
model LabeurInflationState {
  id               String     @id @default(cuid())
  taskId           String     @unique // une seule entrée active par tâche
  task             LabeurTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  daysOverdue           Int       @default(0) // nombre de jours de retard au dernier calcul
  inflationPercent      Float     @default(0) // contribution de cette tâche en % (ecuValue × rate × jours)
  overdueReminderSentAt DateTime?             // date d'envoi du rappel push pour cette instance (null = pas encore envoyé)
  computedAt            DateTime  @default(now()) @updatedAt

  @@index([computedAt])
}

// Réglages globaux du module Labeur — singleton (une seule ligne en base)
model LabeurSettings {
  id                      String   @id @default(cuid())
  inflationCap            Float    @default(150) // plafond d'inflation global en %
  curseSeuil              Float    @default(50)  // seuil de déclenchement de la malédiction en %
  inflationAlertThreshold Float    @default(25)  // seuil d'alerte push en %
  overdueReminderHours        Int       @default(24)  // délai avant rappel pour une tâche récurrente en retard
  oneshotReminderHours        Int       @default(48)  // heures avant dueDate pour rappel tâche ponctuelle
  timezone                    String    @default("Europe/Paris")
  lastInflationAlertSentAt    DateTime?             // debounce 24h : dernière alerte inflation envoyée
  lastCurseAlertSentAt        DateTime?             // debounce 24h : dernière alerte malédiction envoyée
  updatedAt                   DateTime  @updatedAt
}

// ── Labeur — Roadmap ───────────────────────────────────────────────────────────

// Quête collective du foyer — objectif à durée limitée avec récompense Marché (roadmap v3)
model LabeurQuest {
  id                  String            @id @default(cuid())
  title               String
  description         String?           @db.Text
  targetValue         Int               // valeur cible (ex : 10 tâches à réaliser)
  currentValue        Int               @default(0)
  rewardDiscountPct   Int               // réduction accordée sur le Marché à la complétion (%)
  rewardDurationHours Int               // durée de la réduction en heures
  expiresAt           DateTime
  completedAt         DateTime?
  status              LabeurQuestStatus @default(ACTIVE)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([status])
}

// Don d'écu entre membres — roadmap v3
model LabeurEcuGift {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  amount     Int
  message    String?
  sentAt     DateTime @default(now())

  @@index([fromUserId])
  @@index([toUserId])
}

// ── Labeur — Enums ─────────────────────────────────────────────────────────────

// Genre utilisateur pour les titres de seigneur (ajouté sur le modèle User)
enum Gender {
  MALE
  FEMALE
  NEUTRAL
}

// Type de tâche : récurrente (pilotée par LabeurRecurrence) ou ponctuelle
enum LabeurTaskType {
  RECURRING // tâche périodique avec LabeurRecurrence associée
  ONESHOT   // tâche ponctuelle, optionnellement avec dueDate
}

// Statut d'avancement d'une tâche
// PARTIALLY_DONE : tâche partagée avec 1 validation sur 2 (§8.5)
enum LabeurTaskStatus {
  ACTIVE         // en attente de réalisation
  PARTIALLY_DONE // tâche partagée : première validation reçue, en attente de la seconde
  COMPLETED      // réalisée (ou double-validée si partagée)
  ARCHIVED       // archivée manuellement, hors circulation
}

// Fréquence de récurrence — distinct de l'enum Recurrence d'Épargne (MONTHLY/QUARTERLY/ANNUAL)
enum LabeurTaskFrequency {
  DAILY   // tous les jours
  WEEKLY  // toutes les semaines
  MONTHLY // tous les mois
  CUSTOM  // tous les N jours (intervalDays)
}

// Type d'article du Marché
enum LabeurMarketItemType {
  INDIVIDUAL  // récompense personnelle, achat direct
  COLLECTIVE  // récompense partagée, financement 50/50 requis
}

// Nature d'un enregistrement d'achat
enum LabeurPurchaseType {
  INDIVIDUAL              // achat individuel complet
  COLLECTIVE_CONTRIBUTION // contribution partielle à une récompense collective
}

// Fréquence de réinitialisation du stock d'un article du Marché
enum LabeurMarketResetFrequency {
  WEEKLY
  MONTHLY
}

// Statut d'une quête collective (roadmap)
enum LabeurQuestStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

// ── Gamelle ─────────────────────────────────────────────────────────────────────

// Un seul like global par recette (pas de distinction utilisateur en V1)
model RecipeLike {
  id        String   @id @default(cuid())
  recipeId  String   @unique
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// Recettes sélectionnées pour une liste de courses
model ShoppingListRecipe {
  id             String       @id @default(cuid())
  shoppingListId String
  shoppingList   ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  recipeId       String
  recipe         Recipe       @relation(fields: [recipeId], references: [id])
  portions       Int

  @@unique([shoppingListId, recipeId])
  @@index([shoppingListId])
}