generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(cuid())
  name      String
  email     String      @unique
  password  String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  config               UserConfig?
  cerveauEntries       CerveauEntry[]      @relation("CerveauCreatedBy")
  pushSubscriptions    PushSubscription[]
  cerveauPreferences   CerveauPreferences?
  cerveauTemplates     CerveauTemplate[]   @relation("CerveauTemplateCreatedBy")
}

model UserConfig {
  id          String   @id @default(cuid())
  userId      String   @unique
  themeId     String   @default("light")
  preferences String   @db.LongText
  updatedAt   DateTime @updatedAt
  theme       Theme    @relation(fields: [themeId], references: [name])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([themeId], map: "UserConfig_themeId_fkey")
}

model Theme {
  id        String       @id @default(cuid())
  name      String       @unique
  label     String
  isDefault Boolean      @default(false)
  cssVars   String?      @db.LongText
  createdBy String?
  createdAt DateTime     @default(now())
  configs   UserConfig[]
}

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  type          CategoryType
  isFixed       Boolean       @default(false)
  createdAt     DateTime      @default(now())
  isArchived    Boolean       @default(false)
  fixedCharges  FixedCharge[]
  projects      SavingsProject[]
  transactions  Transaction[]
  // ── Budget ──────────────────────────────────────────────────────────────
  budgetLines   BudgetLine[]
  budgetEntries BudgetEntry[]
}

model Transaction {
  id         String   @id @default(cuid())
  month      DateTime
  amount     Float
  detail     String?
  pointed    Boolean  @default(false)
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tags       String   @default("[]") @db.LongText
  category   Category @relation(fields: [categoryId], references: [id])

  @@index([categoryId], map: "Transaction_categoryId_fkey")
}

model FixedCharge {
  id         String   @id @default(cuid())
  month      DateTime
  estimated  Float
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id])

  @@unique([month, categoryId])
  @@index([categoryId], map: "FixedCharge_categoryId_fkey")
}

model SavingsProject {
  id                String              @id @default(cuid())
  name              String
  targetAmount      Float?
  currentAmount     Float               @default(0)
  isActive          Boolean             @default(true)
  categoryId        String?
  transferredToId   String?
  transferredMonth  DateTime?
  transferredAmount Float?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  allocations       SavingsAllocation[]
  category          Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
}

model SavingsAllocation {
  id         String         @id @default(cuid())
  month      DateTime
  percentage Float
  amount     Float
  projectId  String
  createdAt  DateTime       @default(now())
  project    SavingsProject @relation(fields: [projectId], references: [id])

  @@unique([month, projectId])
  @@index([projectId], map: "SavingsAllocation_projectId_fkey")
}

model BankAccount {
  id              String                @id @default(cuid())
  name            String                @unique
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  owner           String                @default("")
  reconciliations ReconciliationEntry[]
}

model Reconciliation {
  id           String                @id @default(cuid())
  month        DateTime              @unique
  totalReal    Float
  totalBdd     Float
  gap          Float
  note         String?
  adjustmentId String?
  createdAt    DateTime              @default(now())
  entries      ReconciliationEntry[]
}

model ReconciliationEntry {
  id               String         @id @default(cuid())
  reconciliationId String
  accountId        String
  balance          Float
  account          BankAccount    @relation(fields: [accountId], references: [id])
  reconciliation   Reconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)

  @@unique([reconciliationId, accountId])
  @@index([accountId])
  @@index([reconciliationId])
}

// ── Budget ─────────────────────────────────────────────────────────────────────

// BudgetLine : template récurrent d'une dépense/revenu prévu
// Ex: "Netflix 5€ tous les mois", "Carte bancaire 15€ tous les 3 mois"
model BudgetLine {
  id               String      @id @default(cuid())
  label            String      // libellé lisible, ex: "Netflix"
  amount           Float       // montant prévu
  categoryId       String
  recurrence       Recurrence  @default(NONE)
  recurrenceMonths Int?        // si CUSTOM : tous les X mois (ex: 3)
  recurrenceStart  DateTime?   // mois de référence pour calculer les échéances
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  category         Category    @relation(fields: [categoryId], references: [id])
  entries          BudgetEntry[]

  @@index([categoryId])
}

// BudgetEntry : instance mensuelle concrète d'une ligne de budget
// Peut être générée automatiquement depuis une BudgetLine récurrente,
// ou créée manuellement (budgetLineId = null)
model BudgetEntry {
  id           String      @id @default(cuid())
  month        DateTime    // mois concerné (normalisé au 1er)
  label        String      // peut différer du template si modif ponctuelle
  amount       Float       // peut différer du template si modif ponctuelle
  categoryId   String
  budgetLineId String?     // null = entrée ponctuelle sans récurrence
  isModified   Boolean     @default(false) // true = modifié après validation du mois
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  category     Category    @relation(fields: [categoryId], references: [id])
  budgetLine   BudgetLine? @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)

  @@index([month])
  @@index([categoryId])
  @@index([budgetLineId])
}

// BudgetMonth : état global du budget pour un mois donné
model BudgetMonth {
  id        String            @id @default(cuid())
  month     DateTime          @unique // normalisé au 1er du mois UTC
  status    BudgetMonthStatus @default(DRAFT)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

// ── Cerveau ────────────────────────────────────────────────────────────────────

model CerveauEntry {
  id           String      @id @default(cuid())
  type         EntryType
  title        String
  body         String?     @db.Text
  status       EntryStatus @default(ACTIVE)
  priority     Priority?
  assignedTo   AssignedTo  @default(BOTH)
  pinned       Boolean     @default(false)

  dueDate      DateTime?
  remindAt     DateTime?
  snoozedUntil DateTime?

  createdById  String
  createdBy    User        @relation("CerveauCreatedBy", fields: [createdById], references: [id])

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  archivedAt   DateTime?
  doneAt       DateTime?

  tags         String?           // JSON array: '["santé","maison"]'
  recurrence   String?           // "quotidien" | "hebdo" | "mensuel" | "annuel"

  notificationCount  Int       @default(0)
  lastNotifiedAt     DateTime?

  listItems    CerveauListItem[]
  children     CerveauEntry[]    @relation("ProjectChildren")
  parentId     String?
  parent       CerveauEntry?     @relation("ProjectChildren", fields: [parentId], references: [id])

  @@index([status])
  @@index([type])
  @@index([assignedTo])
  @@index([dueDate])
  @@index([remindAt])
}

model CerveauListItem {
  id        String       @id @default(cuid())
  entryId   String
  entry     CerveauEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  label     String
  checked   Boolean      @default(false)
  order     Int          @default(0)
  createdAt DateTime     @default(now())

  @@index([entryId])
}

// ── Push Notifications ─────────────────────────────────────────────────────────

model PushSubscription {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  endpoint     String   @db.Text
  p256dh       String   @db.Text
  auth         String
  userAgent    String?
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("PushSubscription")
}

model CerveauPreferences {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eveningStartsAt    String    @default("19:00")
  eventLeadTime      Int       @default(1440)
  quietFrom          String?
  quietUntil         String?
  morningDigestAt    String?   @default("08:00")
  lastDailyDigestAt  DateTime?
  lastWeeklyRecapAt  DateTime?
  weeklyRecapEnabled Boolean   @default(true)
  snoozeSlot1Label   String    @default("15 min")
  snoozeSlot1Minutes Int       @default(15)
  snoozeSlot2Label   String    @default("1 heure")
  snoozeSlot2Minutes Int       @default(60)
  snoozeSlot3Label   String    @default("Ce soir")
  snoozeSlot3Minutes Int?
  snoozeSlot3Dynamic Boolean   @default(true)
  snoozeDefaultSlot  Int       @default(2)
  updatedAt          DateTime  @updatedAt
}

model CerveauTemplate {
  id            String     @id @default(cuid())
  name          String
  shortcut      String?
  type          EntryType
  titlePattern  String
  body          String?    @db.Text
  priority      Priority?
  assignedTo    AssignedTo @default(BOTH)
  tags          String?    @db.Text
  recurrence    String?

  items          CerveauTemplateItem[]

  childTemplates CerveauTemplate[]  @relation("TemplateChildren")
  parentId       String?
  parent         CerveauTemplate?   @relation("TemplateChildren", fields: [parentId], references: [id])

  createdById    String
  createdBy      User               @relation("CerveauTemplateCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([shortcut])
  @@index([createdById])
  @@index([parentId])
}

model CerveauTemplateItem {
  id         String          @id @default(cuid())
  templateId String
  template   CerveauTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  label      String
  order      Int             @default(0)

  @@index([templateId])
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum CategoryType {
  INCOME
  EXPENSE
  PROJECT
}

enum Recurrence {
  NONE      // ponctuel, pas de récurrence
  MONTHLY   // tous les mois
  QUARTERLY // tous les 3 mois
  ANNUAL    // tous les 12 mois
  CUSTOM    // tous les N mois (recurrenceMonths)
}

enum BudgetMonthStatus {
  DRAFT     // en cours de préparation
  VALIDATED // verrouillé comme référence
}

enum EntryType {
  NOTE
  TODO
  REMINDER
  LIST
  PROJECT
  DISCUSSION
  EVENT
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum AssignedTo {
  ILAN
  CAMILLE
  BOTH
}

enum EntryStatus {
  ACTIVE
  DONE
  ARCHIVED
  SNOOZED
}

// ── Popote ─────────────────────────────────────────────────────────────────────

enum BaseUnit {
  GRAM
  MILLILITER
  UNIT
}

enum SlotType {
  DATED
  FLOATING
}

enum Period {
  LUNCH
  DINNER
}

enum RecipeCategory {
  STARTER
  MAIN
  DESSERT
  OTHER
}

model Aisle {
  id          String                @id @default(cuid())
  name        String
  emoji       String?
  order       Int
  ingredients IngredientReference[]
}

model IngredientReference {
  id                 String   @id @default(cuid())
  name               String   @unique
  baseUnit           BaseUnit
  aisleId            String
  aisle              Aisle    @relation(fields: [aisleId], references: [id])
  defaultQuantity    Float?
  conversions        Json?
  quickBuyQuantities Json?
  imageUrl           String?

  recipeIngredients  RecipeIngredient[]
  shoppingListItems  ShoppingListItem[]
  inventory          Inventory?
  substitutionRules  SubstitutionRule[]

  @@index([aisleId])
}

model Recipe {
  id              String             @id @default(cuid())
  title           String
  description     String?            @db.Text
  imageLocal      String
  preparationTime Int?
  cookingTime     Int?
  basePortions    Int                @default(4)
  calories        Int?
  utensils        String?            @db.Text
  steps           Json
  sourceUrl       String?
  jowId           String?            @unique
  category        RecipeCategory?    @default(OTHER)
  createdAt       DateTime           @default(now())
  ingredients     RecipeIngredient[]
  planningSlots   PlanningSlot[]
}

model RecipeIngredient {
  id          String              @id @default(cuid())
  recipeId    String
  recipe      Recipe              @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  referenceId String
  reference   IngredientReference @relation(fields: [referenceId], references: [id])
  quantity        Float
  displayQuantity Float           @default(0)
  displayUnit     String
  isOptional      Boolean         @default(false)
  isStaple        Boolean         @default(false)
  isIgnored       Boolean         @default(false)

  @@index([recipeId])
  @@index([referenceId])
}

model SubstitutionRule {
  id          String              @id @default(cuid())
  jowName     String              @unique
  referenceId String
  reference   IngredientReference @relation(fields: [referenceId], references: [id])
  createdAt   DateTime            @default(now())

  @@index([referenceId])
}

model PlanningSlot {
  id               String    @id @default(cuid())
  recipeId         String
  recipe           Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  type             SlotType
  scheduledDate    DateTime?
  period           Period?
  portions         Int
  portionsConsumed Int       @default(0)
  addedAt          DateTime  @default(now())

  @@index([recipeId])
  @@index([scheduledDate])
}

model ShoppingList {
  id          String             @id @default(cuid())
  generatedAt DateTime           @default(now())
  weekStart   DateTime
  items       ShoppingListItem[]
}

model ShoppingListItem {
  id               String        @id @default(cuid())
  shoppingListId   String
  shoppingList     ShoppingList  @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  referenceId      String?
  reference        IngredientReference? @relation(fields: [referenceId], references: [id])
  label            String
  quantity         Float?
  displayUnit      String?
  plannedQuantity  Float?
  skipped          Boolean       @default(false)
  purchased        Boolean       @default(false)
  purchasedQuantity Float?
  isManual         Boolean       @default(false)

  @@index([shoppingListId])
  @@index([referenceId])
}

model Inventory {
  id          String              @id @default(cuid())
  referenceId String              @unique
  reference   IngredientReference @relation(fields: [referenceId], references: [id])
  quantity    Float
  updatedAt   DateTime            @updatedAt
}