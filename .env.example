# Base de données
MARIADB_ROOT_PASSWORD=rootpassword
MARIADB_DATABASE=family_dashboard
MARIADB_USER=user
MARIADB_PASSWORD=password
DATABASE_URL="mysql://user:password@db:3306/family_dashboard"

# NextAuth
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=<remplacer_par_une_valeur_generee>
NEXTAUTH_URL=https://tribu.camilan.fr
REGISTRATION_SECRET="ton_code_secret_famille"
SEED_USER_NAME="Ton Nom"
SEED_USER_EMAIL="admin@famille.fr"
SEED_USER_PASSWORD="ton-mot-de-passe-ultra-secret"

# Redis (BullMQ workers Cerveau)
# En local : redis://localhost:6379
# En Docker : redis://redis:6379 (valeur par défaut dans docker-compose)
REDIS_URL=redis://redis:6379

# Web Push — Cerveau notifications push
# Générer les clés VAPID avec : npx web-push generate-vapid-keys
# VAPID_SUBJECT : doit être une URL ou une adresse mailto:
VAPID_PUBLIC_KEY=<remplacer_par_cle_publique_vapid>
VAPID_PRIVATE_KEY=<remplacer_par_cle_privee_vapid>
VAPID_SUBJECT=mailto:admin@famille.fr

# Upload fichiers — Cerveau pièces jointes
# UPLOAD_DIR : chemin absolu sur le serveur (doit être accessible en écriture)
# NEXT_PUBLIC_UPLOAD_BASE_URL : URL publique correspondante (servie par Nginx)
UPLOAD_DIR=/uploads/cerveau
NEXT_PUBLIC_UPLOAD_BASE_URL=/uploads/cerveau